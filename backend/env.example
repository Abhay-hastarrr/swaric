# Server
PORT=5000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Security
# Generate a strong random value, e.g. with `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=your_strong_random_secret_here

# Database
# Local MongoDB example. Replace with your Atlas URI if using MongoDB Atlas.
MONGODB_URI=mongodb://127.0.0.1:27017/swaric_auth
